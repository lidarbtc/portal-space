		"@sveltejs/kit": "2.56.1",
		"@types/node": "^22",
		"@types/pngjs": "^6.0.5",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"pngjs": "^7.0.0",
		"svelte": "5.55.1",
		"svelte-check": "^4.0.0",
		"typescript": "^6.0.0",
