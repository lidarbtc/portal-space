{
	"name": "portal-space",
	"private": true,
	"workspaces": [
		"frontend",
		"server"
	],
	"scripts": {
		"build": "bun run --filter @portal-space/frontend build",
		"dev:server": "PORT=3001 bun --watch run server/main.ts",
		"dev:frontend": "bun run --filter @portal-space/frontend dev",
		"test": "bun run --filter @portal-space/frontend test && bun test server/__tests__/",
		"test:server": "bun test server/__tests__/",
		"clean": "rm -rf frontend/build",
		"deploy": "bun run scripts/deploy.ts",
		"db:generate": "bunx drizzle-kit generate --config server/drizzle.config.ts",
		"format": "prettier --write .",
		"lint": "prettier --check . && bun run --filter @portal-space/frontend lint",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,svelte,html,css,json,md,yml,yaml}": "prettier --write",
		"frontend/**/*.{js,ts,svelte}": "bunx eslint --fix",
		"server/**/*.{ts,json}": "bunx biome lint --write --no-errors-on-unmatched"
	},
	"devDependencies": {
		"@types/bun": "^1.3.12",
		"drizzle-kit": "^0.31.10",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1"
	}
}
